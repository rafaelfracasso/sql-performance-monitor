# ============================================================================
# Google Gemini API Key
# ============================================================================
# Obtenha gratuitamente em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# Database Passwords (RECOMENDADO - Variáveis de Ambiente)
# ============================================================================
# IMPORTANTE: Use variáveis de ambiente para senhas em vez de plaintext!
#
# Configure estas variáveis correspondentes às usadas em config/databases.json:
# - Em databases.json: "password": "${SQL_SERVER_PROD_PASSWORD}"
# - Aqui no .env: SQL_SERVER_PROD_PASSWORD=sua_senha_real
#
# Exemplos (descomente e configure conforme necessário):

# SQL Server
# SQL_SERVER_PROD_PASSWORD=your_password_here
# SQL_SERVER_DEV_PASSWORD=your_password_here

# PostgreSQL
# POSTGRESQL_PROD_PASSWORD=your_password_here
# POSTGRESQL_DEV_PASSWORD=your_password_here

# SAP HANA
# HANA_PROD_PASSWORD=your_password_here
# HANA_DEV_PASSWORD=your_password_here

# ============================================================================
# Observações de Segurança
# ============================================================================
# 1. NUNCA commite arquivo .env com credenciais reais (já incluído em .gitignore)
# 2. Use ${VAR_NAME} em databases.json para referenciar variáveis de ambiente
# 3. Senhas em plaintext em databases.json gerarão warning de segurança
# 4. Para produção, considere usar AWS Secrets Manager ou Azure Key Vault
